{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Riemann",
  "version": "0.1.0",
  "identifier": "com.riemann.explorer",
  "build": {
    "frontendDist": "../build",
    "devUrl": null
  },
  "app": {
    "windows": [
      {
        "title": "Riemann Zeta Explorer",
        "width": 1800,
        "height": 1300,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}